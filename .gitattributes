# Normalise all text files to LF in the repo; let git handle OS-specific checkout
* text=auto eol=lf

# Force LF for files that must not have CRLF (YAML, JSON, shell)
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.svg  text eol=lf

# Binary files — no line-ending normalisation
*.png  binary
*.ico  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
